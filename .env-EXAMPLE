# LLM provider/model used by LammpsAgents_by_langgraph.py (code_llm / judge_llm).
# Default is "tongyi" (Alibaba DashScope, requires DASHSCOPE_API_KEY).
# To use an OpenAI-compatible endpoint (OpenAI itself, Moonshot/Kimi, DeepSeek, etc.),
# set provider to "openai" and point OPENAI_API_BASE at that endpoint, e.g.:
#   CODE_LLM_PROVIDER=openai
#   CODE_LLM_MODEL=kimi-k2-0711-preview
#   OPENAI_API_KEY=<your Kimi API key>
#   OPENAI_API_BASE=https://api.moonshot.cn/v1
CODE_LLM_PROVIDER=tongyi
CODE_LLM_MODEL=qwen3-8b
JUDGE_LLM_PROVIDER=tongyi
JUDGE_LLM_MODEL=qwen-flash